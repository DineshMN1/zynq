# ============================================================
# zynqcloud Self-Host Environment
# ============================================================
# Copy this file to .env before running `docker compose up -d`
#
#   cp .env.example .env
#   # Edit .env and fill in your values
#   docker compose up -d
#
# Or use the one-command installer which generates .env for you:
#   curl -fsSL https://raw.githubusercontent.com/Pepperjack-svg/zynq/main/install.sh | bash
# ============================================================

# Docker image to use
ZYNQCLOUD_IMAGE=dineshmn1/zynqcloud:latest

# Host port the app is exposed on (host:container => APP_PORT:80)
APP_PORT=3000

# ── Database ─────────────────────────────────────────────────
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USER=zynqcloud
DATABASE_PASSWORD=change_this_db_password
DATABASE_NAME=zynqcloud

# ── Auth / Crypto (REQUIRED — generate strong values) ────────
# Must be ≥ 32 characters:
#   openssl rand -base64 32
JWT_SECRET=replace_with_strong_secret_at_least_32_chars
JWT_EXPIRES_IN=7d

# Cookie domain — must match your public hostname so cookies are accepted by the browser.
# Local dev:           localhost
# Custom domain:       cloud.example.com  (no scheme, no port)
# Cloudflare Tunnel:   cloud.example.com
COOKIE_DOMAIN=localhost

# Must decode from base64 to exactly 32 bytes:
#   openssl rand -base64 32
FILE_ENCRYPTION_MASTER_KEY=MDEyMzQ1Njc4OWFiY2RlZjAxMjM0NTY3ODlhYmNkZWY=

# ── File storage ─────────────────────────────────────────────
# Host path where uploaded files are stored.
# Relative paths are resolved from the compose project directory.
# Example (Linux/macOS): ./data/files or /opt/zynqcloud/data/files
# Example (Windows Docker Desktop): ./data/files or C:\zynqcloud\data\files
ZYNQ_DATA_PATH=./data/files

# ── App behaviour ─────────────────────────────────────────────
EMAIL_ENABLED=false
INVITE_TOKEN_TTL_HOURS=72
PUBLIC_REGISTRATION=false
RATE_LIMIT_TTL=60000
RATE_LIMIT_MAX=100

# ── URLs ──────────────────────────────────────────────────────
# All three URL variables below must point to your public domain when deploying
# behind a reverse proxy, Cloudflare Tunnel, or any custom domain.
# If any of these are left as localhost, share links, password-reset emails,
# and invite emails will contain localhost URLs instead of your real domain.
#
# Local dev:         http://localhost:3000
# Custom domain:     https://cloud.example.com
# Cloudflare Tunnel: https://cloud.example.com

# Base URL of the frontend — used in email links (password reset, invites, file shares)
FRONTEND_URL=http://localhost:3000

# Allowed CORS origin — must match the URL your browser uses to reach the app.
# Comma-separate to allow multiple origins (e.g. public domain + LAN IP):
#   CORS_ORIGIN=https://cloud.example.com,http://192.168.1.100:3000
CORS_ORIGIN=http://localhost:3000

# ── Security ──────────────────────────────────────────────────
# Set to true when behind HTTPS (Cloudflare Tunnel, reverse proxy, custom domain).
# Set to false only for plain-HTTP LAN / local access without a tunnel.
COOKIE_SECURE=true

# ── Cloudflare Tunnel (optional) ──────────────────────────────
# Expose ZynqCloud on a public domain without opening inbound ports.
#
# Setup steps:
#   1. Cloudflare Zero Trust → Networks → Tunnels → Create a tunnel
#   2. Under "Public Hostname", set the target to:  http://zynqcloud:80
#   3. Copy the tunnel token shown in the dashboard
#   4. Paste it below, then start with:
#        docker compose --profile cloudflare up -d
#   5. Update FRONTEND_URL, CORS_ORIGIN and COOKIE_DOMAIN to your tunnel domain
#
# Notes:
#   - CF-Connecting-IP is read automatically — real visitor IPs work out of the box.
#   - COOKIE_SECURE must be true (Cloudflare always delivers over HTTPS).
#   - You can still access ZynqCloud on the LAN via APP_PORT while the tunnel runs.
CLOUDFLARE_TUNNEL_TOKEN=

# ── SMTP (only used when EMAIL_ENABLED=true) ─────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=zynqcloud <no-reply@yourdomain.com>
