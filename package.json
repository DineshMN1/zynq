{
  "name": "zynqcloud",
  "version": "1.0.0",
  "private": true,
  "description": "Self-hosted file management platform",
  "license": "MIT",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "pnpm --filter @zynqcloud/web build",
    "dev": "node scripts/dev.mjs",
    "dev:db": "docker compose -f docker-compose.dev.yml up -d",
    "dev:api": "node scripts/dev-api.mjs",
    "dev:web": "VITE_API_URL=/api/v1 pnpm --filter @zynqcloud/web dev",
    "lint": "pnpm --filter @zynqcloud/web lint",
    "test": "pnpm --filter @zynqcloud/web test",
    "type-check": "pnpm --filter @zynqcloud/web type-check",
    "clean": "pnpm --filter @zynqcloud/web clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "docker:local": "docker compose -f docker-compose.local.yml up -d --build",
    "docker:prod": "docker compose pull && docker compose up -d",
    "docker:image:current": "bash scripts/docker-image-manager.sh current",
    "docker:image:set": "bash scripts/docker-image-manager.sh set",
    "docker:upgrade": "bash scripts/docker-image-manager.sh upgrade",
    "docker:downgrade": "bash scripts/docker-image-manager.sh downgrade",
    "docker:down": "docker compose down && docker compose -f docker-compose.dev.yml down"
  },
  "devDependencies": {
    "prettier": "^3.2.4"
  },
  "pnpm": {
    "overrides": {
      "glob@>=10.2.0 <10.5.0": ">=10.5.0",
      "webpack@>=5.49.0 <=5.104.0": ">=5.104.1",
      "esbuild@<=0.25.1": ">=0.25.2",
      "tmp@<0.2.3": ">=0.2.3",
      "prismjs@<1.30.0": ">=1.30.0",
      "lodash@>=4.0.0 <=4.17.22": ">=4.17.23"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "eslint": "9"
      }
    }
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
